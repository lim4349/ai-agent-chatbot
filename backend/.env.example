# === App ===
DEBUG=false
LOG_LEVEL=INFO
APP_NAME="AI Agent Chatbot"
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["*"]  # JSON array format, e.g., ["http://localhost:3000", "https://yourapp.com"]

# === LLM Provider ===
LLM_PROVIDER=openai
LLM_MODEL=openrouter/free
LLM_TEMPERATURE=0.5
LLM_MAX_TOKENS=2048
LLM_OPENAI_API_KEY=your_openrouter_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1

# === Memory (Short-term conversation) ===
# Options: in_memory (local dev), redis (production with Upstash)
# TTL: Time-to-live in seconds. After this period of inactivity, session data is deleted.
# - 3600 = 1 hour (default)
# - 7200 = 2 hours
# - 86400 = 24 hours
MEMORY_BACKEND=in_memory
MEMORY_TTL_SECONDS=3600

# === RAG ===
RAG_COLLECTION_NAME=documents
RAG_EMBEDDING_PROVIDER=pinecone  # "openai" or "pinecone"
RAG_EMBEDDING_MODEL=multilingual-e5-large  # OpenAI: text-embedding-3-small, Pinecone: multilingual-e5-large
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=3
RAG_CHUNKING_STRATEGY=auto  # "auto", "default", "code", "tabular"

# Pinecone Configuration (for RAG vector storage)
# Get API key from https://app.pinecone.io
RAG_PINECONE_API_KEY=your_pinecone_api_key_here
RAG_PINECONE_INDEX_NAME=documents
RAG_PINECONE_NAMESPACE=default

# === MCP Servers (Model Context Protocol) ===
MCP_ENABLED=false
MCP_SERVERS_JSON=[]
MCP_DEFAULT_TIMEOUT=30
MCP_HEALTH_CHECK_ENABLED=true
# Example with servers:
# MCP_SERVERS_JSON=[{"name":"github","url":"http://localhost:3001","api_key":"ghp_xxx","tool_prefix":"github"},{"name":"filesystem","url":"http://localhost:3002","tool_prefix":"fs"}]

# === Tools ===
TOOLS_TAVILY_API_KEY=
TOOLS_CODE_EXECUTION_ENABLED=true
TOOLS_CODE_EXECUTION_TIMEOUT=10

# === Session Storage ===
# Auto-detect: if SUPABASE_URL and SUPABASE_SERVICE_KEY are set, uses Supabase
# Otherwise falls back to in_memory (for local development)
# SESSION_BACKEND is optional - auto-detected based on Supabase credentials

# === Supabase (Auth + Session + Long-term Memory) ===
# Used for: Authentication, Session storage, User profiles, Topic memory
# ⚠️ IMPORTANT: Use SERVICE ROLE key, not anon key!
# - service_role: eyJ... (long JWT, bypasses RLS) - USE THIS
# - anon: sb_publishable... (shorter, enforces RLS) - DO NOT USE
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# === Upstash Redis (Session Memory) ===
# Used for: Short-term conversation memory with TTL
# Format: rediss://default:<password>@<endpoint>.upstash.io:6379
MEMORY_REDIS_URL=rediss://default:your_password@your_endpoint.upstash.io:6379

# === LangSmith (Observability & Tracing) ===
# Optional: Enable LangSmith for detailed LLM tracing
# Get API key from https://smith.langchain.com/
OBSERVABILITY__LANGSMITH_TRACING=false
OBSERVABILITY__LANGSMITH_API_KEY=your_langsmith_api_key
OBSERVABILITY__LANGSMITH_PROJECT=ai-agent-chatbot
